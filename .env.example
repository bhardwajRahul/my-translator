# Copy to .env (gitignored) and fill in. Secrets are read at BUILD time.

# macOS notarization (used by scripts/build-notarized.sh)
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Google Free TTS — android-tts endpoint key (embedded at build time via build.rs).
# If unset, the "Google TTS — Free" provider reports "not configured" and is disabled.
GOOGLE_FREE_TTS_KEY=

# Optional: override the app bundle identifier for `npm run dev` (via scripts/tauri-with-env.mjs).
# Set to a distinct id (e.g. com.personal.translator.dev) so the dev build gets its OWN macOS
# Screen-Recording / Microphone permissions, leaving the installed stable app untouched.
# If unset, the default identifier from tauri.conf.json is used.
# APP_IDENTIFIER=com.personal.translator.dev
